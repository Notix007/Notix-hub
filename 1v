createToggle(playerPage, "speedSystemActive", "Speed Custom", 2, function(state)
    local SpeedUiFrame = ScreenGui:FindFirstChild("SpeedUiFrame")
    if SpeedUiFrame then SpeedUiFrame.Visible = state end
    if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = settings.speedSystemActive and settings.currentSpeed or defaultSpeed
    end
end)

createToggle(playerPage, "unwalkActive", "Unwalk", 3, function(state)
    if animTrackConnection then 
        animTrackConnection:Disconnect() 
        animTrackConnection = nil 
    end
    if state and player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        local animator = player.Character:FindFirstChildOfClass("Humanoid"):FindFirstChildOfClass("Animator")
        if animator then
            for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                if track.Name:lower():find("walk") or track.Name:lower():find("run") then track:Stop() end
            end
            animTrackConnection = animator.AnimationPlayed:Connect(function(track)
                if settings.unwalkActive and (track.Name:lower():find("walk") or track.Name:lower():find("run")) then
                    task.wait() track:Stop()
                end
            end)
        end
    end
end)

createToggle(playerPage, "infiniteJumpEnabled", "Infinite Jump", 4, function(state) end)
createToggle(playerPage, "noclipActive", "No Clip", 5, function(state) end)

createToggle(playerPage, "xrayActive", "X-Ray", 6, function(state)
    if state then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj:IsDescendantOf(player.Character) and not obj:IsA("Terrain") then
                if not originalTransparencies[obj] then originalTransparencies[obj] = obj.Transparency end
                obj.Transparency = 0.7 
            end
        end
    else
        for obj, originalValue in pairs(originalTransparencies) do
            if obj and obj.Parent then obj.Transparency = originalValue end
        end
        table.clear(originalTransparencies)
    end
end)

