local nhDragging, nhDragStart, nhStartPos, nhDragInput
NHButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        nhDragging = true 
        nhDragStart = input.Position 
        nhStartPos = NHButton.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then nhDragging = false end end)
    end
end)
NHButton.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then nhDragInput = input end end)
UIS.InputChanged:Connect(function(input)
    if input == nhDragInput and nhDragging then
        local delta = input.Position - nhDragStart
        NHButton.Position = UDim2.new(nhStartPos.X.Scale, nhStartPos.X.Offset + delta.X, nhStartPos.Y.Scale, nhStartPos.Y.Offset + delta.Y)
    end
end)

