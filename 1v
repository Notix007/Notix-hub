-- ==========================================
-- UNIVERSAL PLAYER ESP (ROBUST HIGHLIGHT LOGIC)
-- ==========================================
local function applyESP(targetPlayer)
    if targetPlayer == player then return end
    
    local function addHighlight(char)
        if not char then return end
        
        -- Warten, bis der Charakter vollständig geladen ist
        char:WaitForChild("HumanoidRootPart", 5)
        
        -- Altes Highlight entfernen, falls vorhanden
        if espHighlights[targetPlayer] then
            espHighlights[targetPlayer]:Destroy()
        end
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "NotixESP"
        highlight.Adornee = char
        highlight.FillColor = Color3.fromRGB(200, 50, 50)
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.OutlineTransparency = 0.1
        highlight.Enabled = settings.playerEspActive
        highlight.Parent = CoreGui -- Im CoreGui sichern, damit Game-Scripts es nicht löschen
        
        espHighlights[targetPlayer] = highlight
    end
    
    if targetPlayer.Character then
        addHighlight(targetPlayer.Character)
    end
    targetPlayer.CharacterAdded:Connect(addHighlight)
end

-- ESP Initialisierung & Updates
for _, p in pairs(Players:GetPlayers()) do applyESP(p) end
Players.PlayerAdded:Connect(applyESP)
Players.PlayerRemoving:Connect(function(p)
    if espHighlights[p] then espHighlights[p]:Destroy() espHighlights[p] = nil end
end)

