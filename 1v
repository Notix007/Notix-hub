-- KORRIGIERTE ESP LOGIK
-- ==========================================
local function applyHighlight(targetPlayer)
    if targetPlayer == player or not targetPlayer.Character then return end
    
    local char = targetPlayer.Character
    local highlight = char:FindFirstChild("EspHighlight") or Instance.new("Highlight")
    
    highlight.Name = "EspHighlight"
    highlight.Adornee = char
    highlight.FillColor = Color3.fromRGB(255, 50, 50)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.Enabled = settings.playerEspActive
    highlight.Parent = char
    
    espHighlights[targetPlayer] = highlight
end

createToggle(playerPage, "playerEspActive", "Player ESP", 1, function(state)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            if p.Character then
                local highlight = p.Character:FindFirstChild("EspHighlight")
                if highlight then
                    highlight.Enabled = state
                elseif state then
                    applyHighlight(p)
                end
            end
        end
    end
end)

