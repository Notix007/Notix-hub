-- ==========================================
local function loadSettings()
    if isfile and isfile(fileName) then
        local success, content = pcall(readfile, fileName)
        if success then
            local data = HttpService:JSONDecode(content)
            for k, v in pairs(data) do settings[k] = v end
        end
    end
    
    SpeedInput.Text = tostring(settings.currentSpeed)
    for key, toggleData in pairs(activeToggles) do
        local toggleVis = updateToggleVisual
        if toggleVis then toggleVis(toggleData.Switch, toggleData.Ball, settings[key]) end
        if settings[key] == true then toggleData.Callback(true) end
    end
end

