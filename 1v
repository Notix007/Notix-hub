-- Main Heartbeat Execution Loop (Speed, Noclip, GodFarm)
RunService.Heartbeat:Connect(function()
    if character and humanoid and rootPart then
        -- Speed Check
        if settings.speedSystemActive and humanoid.WalkSpeed ~= settings.currentSpeed then
            humanoid.WalkSpeed = settings.currentSpeed
        end
        
        -- Noclip Check
        if settings.noclipActive then
            for _, part in pairs(character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
        
        -- GodFarm Core Logic
        if settings.farmActive and #gueltigePunkte > 0 and humanoid.Health > 0 then
            local meinPos = rootPart.Position
            
            -- Anti-Stuck Check
            local wegStrecke = (meinPos - letztePosition).Magnitude
            if wegStrecke < 0.5 then
                stillstandZeit = stillstandZeit + 0.016
                if stillstandZeit >= 3.0 then
                    humanoid.Jump = true
                    stillstandZeit = 0
                end
            else
                letztePosition = meinPos
                stillstandZeit = 0
            end
            
            -- Teleport Wartemodus (Drop + Win Tracker)
            if wartetAufTeleport then
                if (meinPos - dropPosition).Magnitude > 35 then
                    task.wait(0.5)
                    local aktuelleWins = holeAktuelleWins()
                    if aktuelleWins > letzteWins then
                        rundenOhneWin = 0
                        letzteWins = aktuelleWins
                    else
                        rundenOhneWin = rundenOhneWin + 1
                        if rundenOhneWin >= maximalFehlversuche then
                            serverRejoin()
                            return
                        end
                    end
                    wartetAufTeleport = false
                    farmAktuellerIndex = 1
                else
                    rootPart.Velocity = Vector3.new(0, rootPart.Velocity.Y, 0)
                    humanoid:Move(Vector3.new(0,0,0))
                end
            else
                local ziel = gueltigePunkte[farmAktuellerIndex]
                if ziel then
                    local aktuellerSpeed = humanoid.WalkSpeed
                    local abstand = math.sqrt((meinPos.X - ziel.X)^2 + (meinPos.Z - ziel.Z)^2)
                    
                    if ziel.Y > (meinPos.Y + 2.5) then
                        rootPart.Velocity = Vector3.new(0, 110, 0)
                        local rX, rZ = ziel.X - meinPos.X, ziel.Z - meinPos.Z
                        local len = math.sqrt(rX^2 + rZ^2)
                        if len > 0 then
                            rootPart.Velocity = Vector3.new((rX / len) * aktuellerSpeed, rootPart.Velocity.Y, (rZ / len) * aktuellerSpeed)
                        end
                    else
                        local richtung = (ziel - meinPos).Unit
                        rootPart.Velocity = Vector3.new(richtung.X * aktuellerSpeed, 0, richtung.Z * aktuellerSpeed)
                        humanoid:MoveTo(ziel)
                    end
                    
                    if abstand < 4.5 and math.abs(meinPos.Y - ziel.Y) < 6 then
                        if farmAktuellerIndex == #gueltigePunkte then
                            dropPosition = meinPos
                            rootPart.Velocity = Vector3.new(0, -40, 0)
                            letzteWins = holeAktuelleWins()
                            wartetAufTeleport = true
                        else
                            farmAktuellerIndex = farmAktuellerIndex + 1
                        end
                    end
                end
            end
        end
    end
end)

