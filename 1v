local menuVisible = true
NHButton.MouseButton1Click:Connect(function()
    menuVisible = not menuVisible
    MainFrame.Visible = menuVisible
    
    -- Unabhängige Fenster werden nur geschlossen, wenn das Hauptmenü zuklappt 
    -- UND das jeweilige Sub-Menü über das Hauptmenü aktiviert wurde (oder manuell).
    -- Hier wird nun abgefragt, ob die Einstellung "true" ist, damit sie offen bleiben dürfen.
    if not menuVisible then
        SpeedUiFrame.Visible = settings.speedSystemActive
        TPSaverFrame.Visible = settings.tpUiOpen
        PlayerTPWindow.Visible = settings.tpPlayerUiOpen
    else
        if settings.speedSystemActive then SpeedUiFrame.Visible = true end
        if settings.tpUiOpen then TPSaverFrame.Visible = true end
        if settings.tpPlayerUiOpen then PlayerTPWindow.Visible = true end
    end
end)

player.CharacterAdded:Connect(function(char)
    local hum = char:WaitForChild("Humanoid")
    task.wait(0.2)
    defaultSpeed = hum.WalkSpeed
    if settings.speedSystemActive then hum.WalkSpeed = settings.currentSpeed end
    if settings.unwalkActive then
        local animator = hum:FindFirstChildOfClass("Animator")
        if animator and animTrackConnection == nil then
            animTrackConnection = animator.AnimationPlayed:Connect(function(track)
                if settings.unwalkActive and (track.Name:lower():find("walk") or track.Name:lower():find("run")) then
                    task.wait() track:Stop()
                end
            end)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local character = player.Character
    if character and character:FindFirstChildOfClass("Humanoid") then
        local hum = character:FindFirstChildOfClass("Humanoid")
        if settings.speedSystemActive and hum.WalkSpeed ~= settings.currentSpeed then
            hum.WalkSpeed = settings.currentSpeed
        end
    end
    if settings.noclipActive and character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

UIS.JumpRequest:Connect(function()
	if settings.infiniteJumpEnabled and player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
		player.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
	end
end)

ApplySpeedButton.MouseButton1Click:Connect(function()
    local targetSpeed = tonumber(SpeedInput.Text)
    if targetSpeed then
        if targetSpeed < 0 then targetSpeed = 0 end
        settings.currentSpeed = targetSpeed
        saveSettings()
        if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
            player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = settings.currentSpeed
        end
        ApplySpeedButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        task.wait(0.15)
        ApplySpeedButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    else
        SpeedInput.Text = "Number!"
    end
end)

ResetSpeedButton.MouseButton1Click:Connect(function()
    settings.currentSpeed = defaultSpeed
    SpeedInput.Text = tostring(defaultSpeed)
    saveSettings()
    if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        player.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = defaultSpeed
    end
    ResetSpeedButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    task.wait(0.15)
    ResetSpeedButton.BackgroundColor3 = Color3.fromRGB(80, 80, 85)
end)

ServerHopButton.MouseButton1Click:Connect(function()
    ServerHopButton.Text = "Searching..."
    local x = pcall(function()
        local Api = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
        local Http = game:HttpGet(Api)
        local Servers = HttpService:JSONDecode(Http)
        if Servers and Servers.data then
            for _, s in pairs(Servers.data) do
                if s.playing and s.playing < s.maxPlayers and s.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, player)
                    break
                end
            end
        end
    end)
    if not x then ServerHopButton.Text = "Error!" task.wait(1) ServerHopButton.Text = "Server Hop ↻" end
end)

