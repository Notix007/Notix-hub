    SpeedInput.Text = tostring(settings.currentSpeed)
    for key, toggleData in pairs(activeToggles) do
        if settings[key] ~= nil then
            updateToggleVisual(toggleData.Switch, toggleData.Ball, settings[key])
            if settings[key] == true then task.spawn(function() toggleData.Callback(true) end) end
        end
    end
end

