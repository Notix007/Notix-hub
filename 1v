-- Save Function
local function saveSettings()
    if writefile then
        if makefolder then makefolder(folderName) end
        local json = HttpService:JSONEncode(settings)
        writefile(fileName, json)
    end
end

-- Update Toggle Visuals
local function updateToggleVisual(switchBtn, ballFrame, isNowActive)
    if isNowActive then
        TweenService:Create(switchBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 200, 50)}):Play()
        TweenService:Create(ballFrame, TweenInfo.new(0.2), {Position = UDim2.new(1, -19, 0, 3)}):Play()
    else
        TweenService:Create(switchBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 55)}):Play()
        TweenService:Create(ballFrame, TweenInfo.new(0.2), {Position = UDim2.new(0, 3, 0, 3)}):Play()
    end
end

-- HELPER FUNCTION: Erstellt ein Toggle-Element fürs Grid-Layout
local function createToggle(parent, settingKey, labelText, layoutOrder, onClickCallback)
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 165, 0, 40)
    Frame.BackgroundTransparency = 0.95
    Frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Frame.LayoutOrder = layoutOrder
    Frame.Parent = parent
    
    local FrameCorner = Instance.new("UICorner")
    FrameCorner.CornerRadius = UDim.new(0, 6)
    FrameCorner.Parent = Frame

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -55, 1, 0)
    Label.Position = UDim2.new(0, 8, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Font = Enum.Font.GothamBold
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(200, 200, 205)
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Frame

    local Switch = Instance.new("TextButton")
    local SwitchCorner = Instance.new("UICorner")
    local SwitchBall = Instance.new("Frame")
    local BallCorner = Instance.new("UICorner")

    Switch.Size = UDim2.new(0, 40, 0, 20)
    Switch.Position = UDim2.new(1, -46, 0, 10)
    Switch.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Switch.Text = ""
    Switch.Parent = Frame
    SwitchCorner.CornerRadius = UDim.new(1, 0)
    SwitchCorner.Parent = Switch

    SwitchBall.Size = UDim2.new(0, 14, 0, 14)
    SwitchBall.Position = UDim2.new(0, 3, 0, 3)
    SwitchBall.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    SwitchBall.Parent = Switch
    BallCorner.CornerRadius = UDim.new(1, 0)
    BallCorner.Parent = SwitchBall

    activeToggles[settingKey] = {Switch = Switch, Ball = SwitchBall, Callback = onClickCallback}

    Switch.MouseButton1Click:Connect(function()
        settings[settingKey] = not settings[settingKey]
        updateToggleVisual(Switch, SwitchBall, settings[settingKey])
        saveSettings()
        onClickCallback(settings[settingKey])
    end)
    
    return Frame
end

