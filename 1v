-- HAUPTSCHLEIFE FÜR GAMEPLAY, ANTI-AFK & FARM
task.spawn(function()
    while true do
        task.wait(0.02)
        
        if laeuft and humanoid and rootPart and humanoid.Health > 0 and #gueltigePunkte > 0 then
            local meinPos = rootPart.Position
            
            local wegStrecke = (meinPos - letztePosition).Magnitude
            if wegStrecke < 0.5 then
                standstillTime = standstillTime + 0.02
                if standstillTime >= 3.0 then
                    humanoid.Jump = true
                    standstillTime = 0
                end
            else
                letztePosition = meinPos
                standstillTime = 0
            end
            
            if wartetAufTeleport then
                local distanzSeitDrop = (meinPos - dropPosition).Magnitude
                if distanzSeitDrop > 35 then
                    task.wait(0.5)
                    local aktuelleWins = holeAktuelleWins()
                    
                    if aktuelleWins > letzteWins then
                        rundenOhneWin = 0
                        letzteWins = aktuelleWins
                        print("Win registriert! Runden-Fehler resettet.")
                    else
                        rundenOhneWin = rundenOhneWin + 1
                        print("Kein Win registriert! Fehlversuche: " .. rundenOhneWin .. "/" .. maximalFehlversuche)
                        if rundenOhneWin >= maximalFehlversuche then
                            serverRejoin()
                            return
                        end
                    end
                    wartetAufTeleport = false
                    aktuellerIndex = 1
                else
                    rootPart.Velocity = Vector3.new(0, rootPart.Velocity.Y, 0)
                    humanoid:Move(Vector3.new(0,0,0))
                end
            else
                local ziel = gueltigePunkte[aktuellerIndex]
                
                if ziel then
                    local aktuellerSpeed = humanoid.WalkSpeed
                    local abstand = math.sqrt((meinPos.X - ziel.X)^2 + (meinPos.Z - ziel.Z)^2)
                    
                    if ziel.Y > (meinPos.Y + 2.5) then
                        rootPart.Velocity = Vector3.new(0, 110, 0)
                        local richtungX = ziel.X - meinPos.X
                        local richtungZ = ziel.Z - meinPos.Z
                        local len = math.sqrt(richtungX^2 + richtungZ^2)
                        if len > 0 then
                            rootPart.Velocity = Vector3.new((richtungX / len) * aktuellerSpeed, rootPart.Velocity.Y, (richtungZ / len) * aktuellerSpeed)
                        end
                    else
                        local richtung = (ziel - meinPos).Unit
                        rootPart.Velocity = Vector3.new(richtung.X * aktuellerSpeed, 0, richtung.Z * aktuellerSpeed)
                        humanoid:MoveTo(ziel)
                    end
                    
                    if abstand < 4.5 and math.abs(meinPos.Y - ziel.Y) < 6 then
                        if aktuellerIndex == #gueltigePunkte then
                            dropPosition = meinPos
                            rootPart.Velocity = Vector3.new(0, -40, 0)
                            letzteWins = holeAktuelleWins()
                            wartetAufTeleport = true
                        else
                            aktuellerIndex = aktuellerIndex + 1
                        end
                    end
                end
            end
        end
    end
end)

