-- Save/Load Functions
local function saveSettings()
    if writefile then
        if makefolder then makefolder(folderName) end
        local json = HttpService:JSONEncode(settings)
        writefile(fileName, json)
    end
end

local function speichereFarmPunkte()
    local daten = {}
    for i = 1, 4 do
        if punkte[i] then
            daten[tostring(i)] = {punkte[i].X, punkte[i].Y, punkte[i].Z}
        end
    end
    if writefile then
        writefile(FARM_DATEI_NAME, HttpService:JSONEncode(daten))
    end
end

local function ladeFarmPunkte()
    if isfile and isfile(FARM_DATEI_NAME) then
        local inhalt = readfile(FARM_DATEI_NAME)
        local erfolg, daten = pcall(function() return HttpService:JSONDecode(inhalt) end)
        if erfolg and type(daten) == "table" then
            for i = 1, 4 do
                if daten[tostring(i)] then
                    local p = daten[tostring(i)]
                    punkte[i] = Vector3.new(p[1], p[2], p[3])
                end
            end
            return true
        end
    end
    return false
end

