repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- Charakter-Variablen
local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

LocalPlayer.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoid = newCharacter:WaitForChild("Humanoid")
    rootPart = newCharacter:WaitForChild("HumanoidRootPart")
end)

-- Positionsspeicher & Status
local pos1 = nil
local pos2 = nil
local laeuft = false
local zielIstPos2 = true -- true = läuft zu Pos 2, false = läuft zu Pos 1

----------------------------------------------------------------
-- UI ERSTELLUNG
----------------------------------------------------------------

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.ResetOnSpawn = false 

local success, err = pcall(function() ScreenGui.Parent = CoreGui end)
if not success then ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui") end

-- Hauptfenster (Frame) für alle Buttons
local MainFrame = Instance.new("Frame")
MainFrame.Name = "PatrouilleUI"
MainFrame.Parent = ScreenGui
MainFrame.Size = UDim2.new(0, 160, 0, 160)
MainFrame.Position = UDim2.new(0, 20, 1, -220) -- Unten links
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 0

local MainCorner = Instance.new("UICorner")
MainCorner.CornerRadius = UDim.new(0, 10)
MainCorner.Parent = MainFrame

-- Funktion zum schnellen Erstellen von schicken Buttons
local function erstelleButton(text, yOffset, farbe)
    local btn = Instance.new("TextButton")
    btn.Parent = MainFrame
    btn.Size = UDim2.new(1, -20, 0, 35)
    btn.Position = UDim2.new(0, 10, 0, yOffset)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = text
    btn.TextColor3 = farbe
    btn.TextSize = 14
    btn.Font = Enum.Font.SourceSansBold
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = farbe
    stroke.Thickness = 1.5
    stroke.Parent = btn
    
    return btn, stroke
end

-- Die 3 Buttons erstellen
local BtnPos1, Stroke1 = erstelleButton("Pos 1 setzen", 15, Color3.fromRGB(255, 170, 0))
local BtnPos2, Stroke2 = erstelleButton("Pos 2 setzen", 60, Color3.fromRGB(0, 170, 255))
local BtnStart, StrokeStart = erstelleButton("START", 105, Color3.fromRGB(255, 75, 75))

----------------------------------------------------------------
-- DRAG-FUNKTION (Fenster verschieben)
----------------------------------------------------------------

local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

----------------------------------------------------------------
-- LOGIK & FUNKTIONEN
----------------------------------------------------------------

-- Position 1 speichern
BtnPos1.MouseButton1Click:Connect(function()
    if rootPart then
        pos1 = rootPart.Position
        BtnPos1.Text = "Pos 1: Gespeichert"
        BtnPos1.TextColor3 = Color3.fromRGB(150, 255, 150)
        Stroke1.Color = Color3.fromRGB(150, 255, 150)
        task.wait(1)
        BtnPos1.Text = "Pos 1 neu setzen"
    end
end)

-- Position 2 speichern
BtnPos2.MouseButton1Click:Connect(function()
    if rootPart then
        pos2 = rootPart.Position
        BtnPos2.Text = "Pos 2: Gespeichert"
        BtnPos2.TextColor3 = Color3.fromRGB(150, 255, 150)
        Stroke2.Color = Color3.fromRGB(150, 255, 150)
        task.wait(1)
        BtnPos2.Text = "Pos 2 neu setzen"
    end
end)

-- Start / Stopp Logik
BtnStart.MouseButton1Click:Connect(function()
    if not pos1 or not pos2 then
        BtnStart.Text = "Erst Pos 1 & 2 setzen!"
        task.wait(1.5)
        BtnStart.Text = laeuft and "STOPP" or "START"
        return
    end
    
    laeuft = not laeuft
    
    if laeuft then
        BtnStart.Text = "STOPP"
        BtnStart.TextColor3 = Color3.fromRGB(75, 255, 75)
        StrokeStart.Color = Color3.fromRGB(75, 255, 75)
        zielIstPos2 = true -- Fängt immer bei Weg zu Position 2 an
    else
        BtnStart.Text = "START"
        BtnStart.TextColor3 = Color3.fromRGB(255, 75, 75)
        StrokeStart.Color = Color3.fromRGB(255, 75, 75)
        if humanoid then
            humanoid:Move(Vector3.new(0,0,0)) -- Sofort anhalten
        end
    end
end)

-- Die Hauptschleife für das Hin- und Herlaufen
RunService.Heartbeat:Connect(function()
    if laeuft and humanoid and rootPart and humanoid.Health > 0 then
        -- Bestimmen, wo wir gerade hinlaufen müssen
        local ziel = zielIstPos2 and pos2 or pos1
        
        -- Charakter dorthin schicken
        humanoid:MoveTo(ziel)
        
        -- Prüfen, wie nah wir am Ziel sind (Abstand berechnen)
        -- 3.5 Studs Toleranz, damit der Charakter nicht hängen bleibt
        local abstand = (rootPart.Position - ziel).Magnitude
        if abstand < 3.5 then
            -- Ziel erreicht! Wechsel zum anderen Punkt
            zielIstPos2 = not zielIstPos2
        end
    end
end)

print("A-B Patrouillen-Script erfolgreich geladen!")
