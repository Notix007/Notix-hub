local function triggerStart()
    table.clear(gueltigePunkte)
    for i = 1, 4 do if punkte[i] then table.insert(gueltigePunkte, punkte[i]) end end
    
    if #gueltigePunkte == 0 then
        BtnStart.Text = "Mind. 1 Punkt setzen!"
        task.wait(1.5)
        BtnStart.Text = laeuft and "STOPP" or "START"
        return
    end
    
    laeuft = not laeuft
    
    if laeuft then
        BtnStart.Text = "STOPP"; BtnStart.TextColor3 = Color3.fromRGB(255, 75, 75); StrokeStart.Color = Color3.fromRGB(255, 75, 75)
        gueltigePunkte = {}
        for i = 1, 4 do if punkte[i] then table.insert(gueltigePunkte, punkte[i]) end end
        aktuellerIndex = 1
        wartetAufTeleport = false
        if rootPart then letztePosition = rootPart.Position end
        standstillTime = 0
        letzteWins = holeAktuelleWins()
        rundenOhneWin = 0
    else
        BtnStart.Text = "START"; BtnStart.TextColor3 = Color3.fromRGB(75, 255, 75); StrokeStart.Color = Color3.fromRGB(75, 255, 75)
        if humanoid then humanoid:Move(Vector3.new(0,0,0)) end
    end
end

