local function aktualisiereButtonDesign(index, button, stroke, name)
    if punkte[index] then
        button.Text = name .. ": Safe"
        button.TextColor3 = Color3.fromRGB(150, 255, 150)
        stroke.Color = Color3.fromRGB(150, 255, 150)
    end
end

local function aktualisiereAlles()
    aktualisiereButtonDesign(1, Btn1, Stroke1, "Punkt 1")
    aktualisiereButtonDesign(2, Btn2, Stroke2, "Punkt 2")
    aktualisiereButtonDesign(3, Btn3, Stroke3, "Punkt 3")
    aktualisiereButtonDesign(4, Btn4, Stroke4, "Punkt 4")
end

local function speicherePunkteInDatei()
    local daten = {}
    for i = 1, 4 do
        if punkte[i] then daten[tostring(i)] = {punkte[i].X, punkte[i].Y, punkte[i].Z} end
    end
    local erfolg, json = pcall(function() return HttpService:JSONEncode(daten) end)
    if erfolg then writefile(DATEI_NAME, json) end
end

local function ladePunkteAusDatei()
    if isfile(DATEI_NAME) then
        local inhalt = readfile(DATEI_NAME)
        local erfolg, daten = pcall(function() return HttpService:JSONDecode(inhalt) end)
        if erfolg and type(daten) == "table" then
            for i = 1, 4 do
                if daten[tostring(i)] then
                    local p = daten[tostring(i)]
                    punkte[i] = Vector3.new(p[1], p[2], p[3])
                end
            end
            return true
        end
    end
    return false
end

local function setzePunkt(index, button, stroke, name)
    if rootPart then
        punkte[index] = rootPart.Position
        aktualisiereButtonDesign(index, button, stroke, name)
        speicherePunkteInDatei()
    end
end

