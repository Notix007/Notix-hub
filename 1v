local function holeAktuelleWins()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        for _, v in pairs(leaderstats:GetChildren()) do
            if string.find(string.lower(v.Name), "win") then return v.Value end
        end
    end
    return 0
end

